# Copy to .env and fill in. `docker compose up` loads this via env_file.
# Use DB_* vars only -- do NOT set DATABASE_URL (it overrides DB_HOST and
# causes localhost connection failures).

APP_ENV=poc

# --- REGION-DEPENDENT: the only values that change on migration ---
AWS_REGION=ap-southeast-1
S3_BUCKET_DOCUMENTS=myco-file-backup-documents-sg
S3_BUCKET_MEDIA=myco-file-backup-media-sg
S3_BUCKET_ARCHIVES=myco-file-backup-archives-sg
DB_HOST=file-backup-db.c9g4u6ekudby.ap-southeast-1.rds.amazonaws.com
DB_PORT=1433
DB_USER=admin
DB_PASSWORD=CHANGE_ME
DB_NAME=filebackup

# --- Local dev only; leave unset on EC2 (IAM role is used instead) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
