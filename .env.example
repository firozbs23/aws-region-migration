# Copy to .env and fill in. On EC2 these are normally set as instance
# environment variables (e.g. via systemd EnvironmentFile) rather than a
# committed .env file.

APP_ENV=poc

# --- REGION-DEPENDENT: the only values that change on migration ---
AWS_REGION=ap-southeast-1
S3_BUCKET_DOCUMENTS=myco-file-backup-documents-sg
S3_BUCKET_MEDIA=myco-file-backup-media-sg
S3_BUCKET_ARCHIVES=myco-file-backup-archives-sg
DATABASE_URL=mssql+pymssql://admin:CHANGE_ME@file-backup-db.c9g4u6ekudby.ap-southeast-1.rds.amazonaws.com:1433/filebackup

# --- Local dev only; leave unset on EC2 (IAM role is used instead) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
