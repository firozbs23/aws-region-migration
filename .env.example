# Copy to .env and fill in. `docker compose up` loads ONLY this file.
# On EC2: do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY -- the
# instance IAM role supplies credentials. Do NOT export AWS_* in your shell.

APP_ENV=poc

# --- REGION-DEPENDENT: the only values that change on migration ---
AWS_REGION=ap-southeast-1
S3_BUCKET_DOCUMENTS=myco-file-backup-documents-sg
S3_BUCKET_MEDIA=myco-file-backup-media-sg
S3_BUCKET_ARCHIVES=myco-file-backup-archives-sg
S3_PUBLIC_ACCESS=true
DB_HOST=file-backup-db.c9g4u6ekudby.ap-southeast-1.rds.amazonaws.com
DB_PORT=1433
DB_USER=admin
DB_PASSWORD=CHANGE_ME
DB_NAME=filebackup

# --- Local laptop dev only (omit these lines on EC2) ---
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
