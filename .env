# Copy to .env (project root) before `docker compose up`. Compose reads
# this for ${VAR} interpolation; it's NOT mounted into the container, and
# DATABASE_URL isn't set here -- compose derives it from MSSQL_* + the `db`
# service name. NOTE: shell-exported AWS_* vars win over this file,
# per-variable -- run `env | grep AWS_` first if region-info looks wrong.

APP_ENV=poc

# --- REGION-DEPENDENT: the only 4 values here that change on migration ---
AWS_REGION=ap-southeast-1
S3_BUCKET_DOCUMENTS=myco-file-backup-documents-sg
S3_BUCKET_MEDIA=myco-file-backup-media-sg
S3_BUCKET_ARCHIVES=myco-file-backup-archives-sg

# --- Local dev only; leave unset on EC2 (IAM instance role used instead) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- db container bootstrap (dev/POC only; mssql-server only ever creates
# the built-in "sa" login, same shape as RDS's one master login) ---
MSSQL_SA_PASSWORD=Ch4ngeMe!Str0ng
MSSQL_DB=filebackup
