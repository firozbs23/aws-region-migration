# Copy from .env.example and fill in. Compose loads this into the container
# via env_file. Do NOT set DATABASE_URL here -- use DB_* vars only.
# NOTE: shell-exported AWS_* vars win over this file, per-variable --
# run `env | grep AWS_` first if region-info looks wrong.

APP_ENV=poc

# --- REGION-DEPENDENT: the only values that change on migration ---
AWS_REGION=ap-southeast-1
S3_BUCKET_DOCUMENTS=myco-file-backup-documents-sg
S3_BUCKET_MEDIA=myco-file-backup-media-sg
S3_BUCKET_ARCHIVES=myco-file-backup-archives-sg
DB_HOST=file-backup-db.c9g4u6ekudby.ap-southeast-1.rds.amazonaws.com
DB_PORT=1433
DB_USER=admin
DB_PASSWORD=demo-password
DB_NAME=filebackup

# --- Local dev only; leave unset on EC2 (IAM instance role used instead) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
